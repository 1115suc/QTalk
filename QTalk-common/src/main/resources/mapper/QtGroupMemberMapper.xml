<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="course.QTalk.mapper.QtGroupMemberMapper">

    <resultMap id="BaseResultMap" type="course.QTalk.pojo.po.QtGroupMember">
        <id property="id" column="id"/>
        <result property="groupId" column="group_id"/>
        <result property="userUid" column="user_uid"/>
        <result property="role" column="role"/>
        <result property="alias" column="alias"/>
        <result property="isTop" column="is_top"/>
        <result property="isDisturb" column="is_disturb"/>
        <result property="lastReadSeq" column="last_read_seq"/>
        <result property="muteEndTime" column="mute_end_time"/>
        <result property="joinType" column="join_type"/>
        <result property="isQuit" column="is_quit"/>
        <result property="joinTime" column="join_time"/>
        <result property="leaveTime" column="leave_time"/>
        <result property="extra" column="extra"/>
    </resultMap>

    <resultMap id="GroupMemberMap" type="course.QTalk.pojo.bo.GroupMemberInfoBO">
        <result property="uid" column="user_uid"/>
        <result property="alias" column="alias"/>
        <result property="role" column="role"/>
        <result property="avatar" column="avatar"/>
    </resultMap>


    <sql id="Base_Column_List">
        id,group_id,user_uid,role,alias,is_top,
        is_disturb,last_read_seq,mute_end_time,join_type,is_quit,
        join_time,leave_time,extra
    </sql>

    <select id="selectGroupMembersInfo" resultType="course.QTalk.pojo.bo.GroupMemberInfoBO">
        select member.user_uid as uid,
               member.alias as alias,
               member.role as role,
               user.avatar as avatar
        from QTalk.qt_group_member member
                 left join QTalk.sys_user user on member.user_uid = user.uid
        where member.group_id = #{groupId}
    </select>
</mapper>
